<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\FrameXML\UI.xsd">
    <Frame name="MIOG_ProgressCheck" mixin="ProgressCheckMixin" virtual="true">
        <Frames>
            <!--<Frame parentKey="HeaderContainer">
                <Size y="20"/>
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="TOPRIGHT"/>
                </Anchors>
            </Frame>!-->

            <Frame parentKey="ScrollBox" inherits="WowScrollBoxList">
                <Anchors>
                    <Anchor point="TOPLEFT"/>
                    <Anchor point="BOTTOMRIGHT" />
                </Anchors>
            </Frame>

            <EventFrame parentKey="ScrollBar" inherits="MinimalScrollBar">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.ScrollBox" relativePoint="TOPRIGHT"/>
                    <Anchor point="BOTTOMLEFT" relativeKey="$parent.ScrollBox" relativePoint="BOTTOMRIGHT" />
                </Anchors>
            </EventFrame>
        </Frames>

        <Scripts>
            <OnLoad method="OnLoad" />  
            <OnShow method="OnShow" />
        </Scripts>
    </Frame>

    <Frame name="MIOG_ProgressCheckHeaderTemplate" mixin="ProgressCheckHeaderMixin" virtual="true">
        <Size x="100" y="16"/>
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="Text" font="GameFontHighlight" justifyH="LEFT" justifyV="MIDDLE" outline="NORMAL" setAllPoints="true"/>
            </Layer>
        </Layers>
    </Frame>

    <Frame name="MIOG_ProgressCheckRowTemplate" mixin="ProgressCheckRowMixin" virtual="true">
        <Size x="100" y="16"/>
        <Layers>
            <Layer level="BACKGROUND">
				<Texture parentKey="Background" setAllPoints="true" />
            </Layer>
        </Layers>
    </Frame>

    <Frame name="MIOG_ProgressCheckCellTemplate" mixin="ProgressCheckCellMixin" virtual="true">
        <Size y="16"/>
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="Text" font="GameFontHighlight" justifyH="LEFT" justifyV="MIDDLE" outline="NORMAL" setAllPoints="true"/>
            </Layer>
        </Layers>
    </Frame>
</Ui>