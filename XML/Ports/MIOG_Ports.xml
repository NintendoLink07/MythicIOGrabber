<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\FrameXML\UI.xsd">
    <Frame name="MIOG_Ports" mixin="PortsMixin" virtual="true">
        <Frames>
            <Frame parentKey="ActiveSeason" inherits="MIOG_PortsGroupTemplate">
                <Size y="120" />
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent" relativePoint="TOPLEFT"/>
                    <Anchor point="TOPRIGHT" relativeKey="$parent" relativePoint="TOP"/>
                </Anchors>
            </Frame>

            <Frame parentKey="Left" inherits="TooltipBorderBackdropTemplate, VerticalLayoutFrame">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.ActiveSeason" relativePoint="BOTTOMLEFT"/>
                    <Anchor point="BOTTOMRIGHT" relativeKey="$parent" relativePoint="BOTTOM"/>
                </Anchors>

                <KeyValues>
                    <KeyValue key="topPadding" value="10" type="number"/>
                    <KeyValue key="bottomPadding" value="10" type="number"/>
                    <KeyValue key="leftPadding" value="10" type="number"/>
                    <KeyValue key="rightPadding" value="10" type="number"/>
                    <KeyValue key="spacing" value="6" type="number"/>
                </KeyValues>

                <Frames>
                    <Frame parentKey="Groups3" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="1" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>

                    <Frame parentKey="Groups4" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="3" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>

                    <Frame parentKey="Groups5" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="5" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>

                    <Frame parentKey="Groups6" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="7" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>
                </Frames>

                <Layers>
                    <Layer level="ARTWORK">
                        <Texture atlas="UI-LFG-DividerLine" useAtlasSize="false">
                            <Size y="2" />

                            <KeyValues>
                                <KeyValue key="layoutIndex" value="2" type="number" />
                                <KeyValue key="expand" value="true" type="boolean" />
			                    <KeyValue key="align" value="center" type="string"/>
                            </KeyValues>
                        </Texture>

                        <Texture atlas="UI-LFG-DividerLine" useAtlasSize="false">
                            <Size y="2" />

                            <KeyValues>
                                <KeyValue key="layoutIndex" value="4" type="number" />
                                <KeyValue key="expand" value="true" type="boolean" />
			                    <KeyValue key="align" value="center" type="string"/>
                            </KeyValues>
                        </Texture>

                        <Texture atlas="UI-LFG-DividerLine" useAtlasSize="false">
                            <Size y="2" />

                            <KeyValues>
                                <KeyValue key="layoutIndex" value="6" type="number" />
                                <KeyValue key="expand" value="true" type="boolean" />
			                    <KeyValue key="align" value="center" type="string"/>
                            </KeyValues>
                        </Texture>
                    </Layer>
                </Layers>
            </Frame>

            <Frame parentKey="Right" inherits="TooltipBorderBackdropTemplate, VerticalLayoutFrame">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent" relativePoint="TOP"/>
                    <Anchor point="BOTTOMRIGHT" relativeKey="$parent" relativePoint="BOTTOMRIGHT"/>
                </Anchors>

                <KeyValues>
                    <KeyValue key="topPadding" value="10" type="number"/>
                    <KeyValue key="bottomPadding" value="10" type="number"/>
                    <KeyValue key="leftPadding" value="10" type="number"/>
                    <KeyValue key="rightPadding" value="10" type="number"/>
                    <KeyValue key="spacing" value="6" type="number"/>
                </KeyValues>

                <Frames>
                    <Frame parentKey="Groups7" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="1" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>

                    <Frame parentKey="Groups8" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="3" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>

                    <Frame parentKey="Groups9" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="5" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>

                    <Frame parentKey="Groups10" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="7" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>

                    <Frame parentKey="Groups11" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="9" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>

                    <Frame parentKey="Groups12" inherits="MIOG_PortsGroupTemplate">
                        <KeyValues>
                            <KeyValue key="layoutIndex" value="11" type="number" />
                            <KeyValue key="expand" value="true" type="boolean" />
                        </KeyValues>
                    </Frame>
                </Frames>

                <Layers>
                    <Layer level="ARTWORK">
                        <Texture atlas="UI-LFG-DividerLine" useAtlasSize="false">
                            <Size y="2" />

                            <KeyValues>
                                <KeyValue key="layoutIndex" value="2" type="number" />
                                <KeyValue key="expand" value="true" type="boolean" />
			                    <KeyValue key="align" value="center" type="string"/>
                            </KeyValues>
                        </Texture>

                        <Texture atlas="UI-LFG-DividerLine" useAtlasSize="false">
                            <Size y="2" />

                            <KeyValues>
                                <KeyValue key="layoutIndex" value="4" type="number" />
                                <KeyValue key="expand" value="true" type="boolean" />
			                    <KeyValue key="align" value="center" type="string"/>
                            </KeyValues>
                        </Texture>

                        <Texture atlas="UI-LFG-DividerLine" useAtlasSize="false">
                            <Size y="2" />

                            <KeyValues>
                                <KeyValue key="layoutIndex" value="6" type="number" />
                                <KeyValue key="expand" value="true" type="boolean" />
			                    <KeyValue key="align" value="center" type="string"/>
                            </KeyValues>
                        </Texture>

                        <Texture atlas="UI-LFG-DividerLine" useAtlasSize="false">
                            <Size y="2" />

                            <KeyValues>
                                <KeyValue key="layoutIndex" value="8" type="number" />
                                <KeyValue key="expand" value="true" type="boolean" />
			                    <KeyValue key="align" value="center" type="string"/>
                            </KeyValues>
                        </Texture>
                    </Layer>
                </Layers>
            </Frame>
        </Frames> 

        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="Name" font="GameFontHighlightLarge" justifyH="CENTER" justifyV="MIDDLE" outline="THICK" text="ARENA_THIS_SEASON">
                    <Anchors>
                        <Anchor point="TOP" relativeKey="$parent.ActiveSeason" relativePoint="TOP" y="-6"/>
                    </Anchors>
                </FontString>
            </Layer>

            <Layer level="BORDER">
                <Texture parentKey="Border" atlas="questlog-frame" setAllPoints="true">
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.ActiveSeason"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.ActiveSeason"/>
                    </Anchors>

                </Texture>
            </Layer>
        </Layers>

        <Scripts>
            <OnLoad method="OnLoad" />
        </Scripts>
    </Frame>
</Ui>