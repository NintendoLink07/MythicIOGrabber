<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\FrameXML\UI.xsd">
    <Frame name="MIOG_Ports" mixin="PortsMixin" virtual="true">
        <Frames>
            <Frame parentKey="ActiveSeason" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent" relativePoint="TOPLEFT"/>
                </Anchors>

                <Layers>
                    <Layer level="OVERLAY">
                        <FontString parentKey="Name" font="GameFontHighlightMedium" justifyH="CENTER" justifyV="MIDDLE" outline="NORMAL" text="ARENA_THIS_SEASON" >
                            <Anchors>
                                <Anchor point="CENTER" relativePoint="TOP"/>
                            </Anchors>
                        </FontString>
                    </Layer>

                    <Layer level="BORDER">
				        <Texture parentKey="Border" atlas="questlog-frame" setAllPoints="true"/>
                    </Layer>
                </Layers>
            </Frame>

            <Frame parentKey="Groups3" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.ActiveSeason" relativePoint="BOTTOMLEFT" y="-6"/>
                </Anchors>
            </Frame>
            
            <Frame parentKey="Groups4" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups3" relativePoint="BOTTOMLEFT"/>
                </Anchors>
            </Frame>
            
            <Frame parentKey="Groups5" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups4" relativePoint="BOTTOMLEFT"/>
                </Anchors>
            </Frame>
            
            <Frame parentKey="Groups6" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups5" relativePoint="BOTTOMLEFT"/>
                </Anchors>
            </Frame>
            
            <Frame parentKey="Groups7" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.ActiveSeason" relativePoint="TOPRIGHT" x="2"/>
                </Anchors>
            </Frame>
            
            <Frame parentKey="Groups8" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups7" relativePoint="BOTTOMLEFT"/>
                </Anchors>
            </Frame>
            <Frame parentKey="Groups9" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups8" relativePoint="BOTTOMLEFT"/>
                </Anchors>
            </Frame>
            
            <Frame parentKey="Groups10" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups9" relativePoint="BOTTOMLEFT"/>
                </Anchors>
            </Frame>
            
            <Frame parentKey="Groups11" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups10" relativePoint="BOTTOMLEFT"/>
                </Anchors>
            </Frame>
            
            <Frame parentKey="Groups12" inherits="MIOG_PortsGroupTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups11" relativePoint="BOTTOMLEFT"/>
                </Anchors>
            </Frame>

            <Frame inherits="TooltipBorderBackdropTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups3"/>
                    <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Groups6" y="-4"/>
                </Anchors>
            </Frame>

            <Frame inherits="TooltipBorderBackdropTemplate">
                <Anchors>
                    <Anchor point="TOPLEFT" relativeKey="$parent.Groups7"/>
                    <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Groups11" y="-4"/>
                </Anchors>
            </Frame>
        </Frames> 

        <Scripts>
            <OnLoad method="OnLoad" />
        </Scripts>
    </Frame>
</Ui>