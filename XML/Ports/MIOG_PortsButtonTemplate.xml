<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\FrameXML\UI.xsd">
    <Button name="MIOG_PortsButtonTemplate" inherits="SecureActionButtonTemplate" mixin="PortsButtonMixin" virtual="true">
        <Size x="28" y="28" />

        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="Text" font="GameFontHighlight" justifyH="CENTER" justifyV="MIDDLE" outline="THICK">
                    <Anchors>
                        <Anchor point="BOTTOM" relativeKey="$parent" relativePoint="BOTTOM" y="1"/>
                    </Anchors>
                </FontString>

                <Texture parentKey="TransparentDark">
                    <Color r="0.1" g="0.1" b="0.1" a="0.6" />
                    
                    <Anchors>
                        <Anchor point="TOPLEFT" relativeKey="$parent.Text" x="-4"/>
                        <Anchor point="BOTTOMRIGHT" relativeKey="$parent.Text" x="4"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers> 

        <Scripts>
            <OnLoad method="OnLoad" />
            <OnLeave function="GameTooltip_Hide" />
        </Scripts>
    </Button>
</Ui>