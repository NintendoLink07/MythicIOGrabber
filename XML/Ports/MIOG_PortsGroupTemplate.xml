<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\FrameXML\UI.xsd">
    <Button name="MIOG_PortsGroupTemplate" mixin="PortsGroupMixin" virtual="true">
        <Layers>
            <Layer level="OVERLAY" textureSubLevel="7">
                <Texture parentKey="Icon">
                    <Size x="18" y="18" />
                    <Anchors>
                        <Anchor point="CENTER" relativeKey="$parent" relativePoint="TOPLEFT" x="-3" y="6"/>
                    </Anchors>
                </Texture>
            </Layer>
        </Layers>

        <Frames>
            <Frame parentKey="Subgroup" inherits="StaticGridLayoutFrame" setAllPoints="true"/>
        </Frames>

        <Scripts>
            <OnLoad method="OnLoad" />
        </Scripts>
    </Button>
</Ui>