<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\FrameXML\UI.xsd">
    <Frame name="MIOG_GroupCreator" mixin="GroupCreatorMixin" virtual="true">
        <Layers>
            <Layer level="OVERLAY">
                <FontString parentKey="CategoryName" font="GameFontHighlight" justifyH="CENTER" justifyV="MIDDLE" outline="NORMAL" wordwrap="false" text="CATEGORY">
                    <Anchors>
                        <Anchor point="TOP" y="-11"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>

        <!--<Layers>
            <Layer level="ARTWORK">
                <FontString parentKey="Label" inherits="QuestFont_Huge" text="START_A_GROUP">
                    <Anchors>
                        <Anchor point="TOP" x="-3" y="-35"/>
                    </Anchors>
                    <Color r="1.0" g="0.82" b="0"/>
