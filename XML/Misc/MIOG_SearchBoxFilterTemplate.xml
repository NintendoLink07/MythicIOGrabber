<Ui xmlns="http://www.blizzard.com/wow/ui/" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:schemaLocation="http://www.blizzard.com/wow/ui/
..\..\FrameXML\UI.xsd">
    <Frame name="MIOG_SearchBoxFilterTemplate" virtual="true">
        <Size y="16" />

        <Frames>
            <Button parentKey="Cancel" inherits="UIResetButtonTemplate" hidden="false">
                <Size x="14" y="14" />

                <Anchors>
                    <Anchor point="RIGHT" relativeKey="$parent" x="-2"/>
                </Anchors>
            </Button>
        </Frames>

        <Layers>
            <Layer level="BACKGROUND">
                <Texture parentKey="Left" inherits="UI-PaperOverlay-PaperHeader-SelectUp-Left">
                    <Size x="16" y="16" />
                    <Anchors>
                        <Anchor point="LEFT"/>
                    </Anchors>
                </Texture>
                <Texture parentKey="Right" inherits="UI-PaperOverlay-PaperHeader-SelectUp-Right" >
                    <Size x="16" y="16" />
                    <Anchors>
                        <Anchor point="RIGHT"/>
                    </Anchors>
                </Texture>
            </Layer>

			<Layer level="BACKGROUND" textureSubLevel="-2">
                <Texture parentKey="Middle" inherits="UI-PaperOverlay-PaperHeader-SelectUp-Mid">
                    <Size y="16" />
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent.Left" x="8" y="0"/>
                        <Anchor point="RIGHT" relativeKey="$parent.Right" x="-8" y="0"/>
                    </Anchors>
                </Texture>
            </Layer>

            <Layer level="OVERLAY">
                <FontString parentKey="Name" font="GameFontHighlightSmall" justifyH="LEFT" justifyV="MIDDLE">
                    <Anchors>
                        <Anchor point="LEFT" relativeKey="$parent" x="4" y="1"/>
                        <Anchor point="RIGHT" relativeKey="$parent.Cancel" relativePoint="LEFT" x="2" y="1"/>
                    </Anchors>
                </FontString>
            </Layer>
        </Layers>
    </Frame>
</Ui>